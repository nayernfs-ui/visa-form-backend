# ══════════════════════════════════════════
#  VISA FORM BACKEND — Environment Config
# ══════════════════════════════════════════

# Gmail account that SENDS the email
EMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your normal password)
# Generate at: https://myaccount.google.com/apppasswords
# Steps: Google Account → Security → 2-Step Verification → App passwords
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# Email address that RECEIVES the filled forms
EMAIL_TO=your_email@gmail.com

# Server port (optional, default 3001)
PORT=3001
